---
import defaultCv from "../../../cv.json";
const cv = Astro.props.cv || defaultCv;
const lang = Astro.props.lang || "es";
const { skills } = cv;
import GitHub from "../../icons/GitHub.astro";
import React from "../../icons/react.astro";
import HTML from "../../icons/html.astro";
import CSS from "../../icons/css.astro";
import Git from "../../icons/git.astro";
import Node from "../../icons/node.astro";
import SQL from "../../icons/sql.astro";
import MySQL from "../../icons/mysql.astro";
import Javascript from "../../icons/javascript.astro";
import AstroIcon from "../../icons/Astro.astro";
import MongoDB from "../../icons/MongoDB.astro";
import Express from "../../icons/Express.astro";
import Tailwind from "../../icons/tailwind.astro";
import N8n from "../../icons/N8n.astro";
import Supabase from "../../icons/Supabase.astro";
import TypeScript from "../../icons/typescript.astro";
import Postman from "../../icons/Postman.astro";
import DockerIcon from "../../icons/DockerIcon.astro";
import MercadoPago from "../../icons/MercadoPago.astro";
import Google from "../../icons/Google.astro";
import Telegram from "../../icons/Telegram.astro";
import Webhooks from "../../icons/Webhooks.astro";
import Rag from "../../icons/Rag.astro";
import OCR from "../../icons/OCR.astro";
import OpenAI from "../../icons/OpenAi.astro";

const SKILLS_ICONS = {
  HTML,
  CSS,
  Javascript,
  TypeScript,
  React,
  Node,
  SQL,
  MySQL,
  Git,
  GitHub,
  Astro: AstroIcon,
  MongoDB,
  Express,
  Tailwind,
  N8n,
  Supabase,
  Docker: DockerIcon,
  Postman,
  "Mercado Pago SDK": MercadoPago,
  "Google Sheets API": Google,
  "Telegram API": Telegram,
  Webhooks,
  RAG: Rag,
  OCR,
  "OpenAI API": OpenAI,
};
---

<section>
  <h3>{lang === "en" ? "Skills" : "Habilidades"}</h3>
  <ul>
    {
      skills.map(({ name, level }) => {
        const iconName = name === "JavaScript" ? "Javascript" : name;
        const Icon = SKILLS_ICONS[iconName];
        return (
          <li>
            {/* <span class="level">{level}</span> */}
            {Icon && <Icon />} <span>{name}</span>
          </li>
        );
      })
    }
  </ul>
</section>

<style>
  ul {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 1em;
  }

  li {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.2em;
    font-size: 1.1em;
    font-weight: 500;
    padding: 5px 10px;
    background-color: #0000000e;
    border-radius: 10px;
    transition: opacity 0.2s;
    cursor: pointer;
  }

  .level {
    position: absolute;
    top: -10px;
    right: -20px;
    background-color: rgba(0, 0, 0, 0.8);
    padding: 2px 5px;
    border-radius: 5px;
    color: white;
    opacity: 0;
    transition: opacity 0.2s;
  }

  li:hover .level {
    opacity: 1;
  }

  li:hover {
    opacity: 0.5;
  }

  @media (width <= 700px) {
    li {
      font-size: 0.8em;
    }
  }

  @media print {
    ul {
      gap: 0.8em;
    }

    li {
      font-size: 0.8em;
    }
  }
</style>
